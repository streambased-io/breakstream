        },
        "Name": {
          "_gen": "string",
          "expr": "#{Name.full_name}"
        },
        "Address": {
          "_gen": "string",
          "expr": "#{Address.full_address}"
        },
        "Email": {
          "_gen": "string",
          "expr": "#{Internet.email_address}"
        },
        "PhoneNo": {
