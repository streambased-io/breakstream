      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "infinity"
      },
      "description": "Leaderboard derived from control events by pairing each session's name with its numeric score.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "score"
          }
        ]
      },
      "pluginVersion": "12.0.0",
      "targets": [
        {
          "columns": [
            {
              "selector": "name",
              "text": "name",
              "type": "string"
            },
            {
              "selector": "score",
              "text": "score",
              "type": "number"
            }
          ],
          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "infinity"
          },
          "format": "table",
          "parser": "backend",
          "refId": "A",
          "root_selector": "$.rows",
          "source": "url",
          "type": "json",
          "url": "/api/query",
          "url_options": {
            "body_content_type": "application/json",
            "body_type": "raw",
            "data": "{\n  \"set\": \"HOT\",\n  \"sql\": \"SELECT name, score FROM (SELECT sessionId, MAX(CASE WHEN event_type = 'name' THEN data END) AS name, MAX(CASE WHEN event_type = 'score' AND data RLIKE '^[0-9]+$' THEN CAST(data AS INT) END) AS score FROM control_events GROUP BY sessionId) leaderboard WHERE name IS NOT NULL AND score IS NOT NULL ORDER BY score DESC, name ASC\",\n  \"index\": true\n}",
            "method": "POST"
          }
        }
      ],
      "title": "Leaderboard",
      "type": "table"
    }
  ],
